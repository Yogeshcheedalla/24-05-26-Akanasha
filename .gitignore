# AkanshaLive Project - Root Gitignore

# Dependencies
node_modules/
.pnp/
.pnp.*

# Environment and local secrets
.env
.env.*
!.env.example

# Next.js / React / production output
.next/
out/
dist/
build/
.turbo/

# Logs and diagnostics
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dev-server.log
frontend-dev.log

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/

# Test and coverage output
coverage/
test-results/
playwright-report/
.playwright/

# OS-specific files
.DS_Store
Thumbs.db
desktop.ini

# Deployment / tooling
.vercel/

# TypeScript
*.tsbuildinfo

# IDEs
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Databases and local storage
*.db
*.sqlite
*.sqlite3

# Generated project artifacts
graphify-out/
tmp_*/
aura/tmp_voice_recording_frames/
aura/codechef-login.html
aura/tmp-chat.html
aura/debug_prompt.txt

# Agent logs
.agent/
.codex/

# SQLite sidecars
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm
*.sqlite3-wal
*.sqlite3-shm

# Akansha/Hermes runtime databases and local stores
aura/backend/hermes/database/*.db
aura/backend/hermes/database/*.db-*
aura/backend/hermes/database/*.sqlite
aura/backend/hermes/database/*.sqlite*
aura/backend/hermes/database/*.sqlite3
aura/backend/hermes/database/*.sqlite3*
aura/backend/uploads/
aura/backend/generated/
aura/backend/tmp/
aura/backend/.cache/
aura/backend/local_storage/
aura/backend/memory/
aura/backend/vector_store/
aura/backend/chroma/
aura/backend/faiss/

# Generated artifacts and exports
generated/
downloads/
exports/
artifacts/
aura/public/generated/
aura/generated/
aura/downloads/
aura/exports/
aura/artifacts/

# Voice, screenshot, and media scratch files
recordings/
screenshots/
aura/recordings/
aura/screenshots/
*.webm
*.wav
*.mp3.tmp
*.mp4.tmp
*.png.tmp
*.jpg.tmp

# Provider/tool caches and local config
.openrouter-cache/
.openai-cache/
.mcp-cache/
.codex-cache/
*.local.json
*.local.yaml
*.local.yml
